{
  "name": "hs-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "test:unit": "turbo run test:unit",
    "test:e2e": "pnpm --filter @hs/web-tasks test:e2e",
    "build-only": "turbo run build-only",
    "typecheck": "turbo run typecheck",
    "gen:api": "pnpm --filter @hs/web-tasks gen:api",
    "dev:api": "pnpm --filter @hs/web-tasks dev:api",
    "dev:api:logs": "pnpm --filter @hs/web-tasks dev:api:logs",
    "dev:api:down": "pnpm --filter @hs/web-tasks dev:api:down",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "format:check": "turbo run format:check"
  },
  "devDependencies": {
    "turbo": "^2.5.3"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
